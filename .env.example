# ============================================================
# LINE Bot Configuration
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ============================================================
# Supabase Configuration (Database + Storage)
# ============================================================
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key (server-side only — bypasses RLS)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================================
# Groq AI Configuration (OCR + financial message parsing)
# Get your API key at https://console.groq.com/keys
# ============================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=llama-3.2-90b-vision-preview
# 0 = auto from gemini-timing.ts (default ~2000ms); override after npm run benchmark:natural-reply
AI_NATURAL_REPLY_TIMEOUT_MS=0

# AI command-learning: interpret & self-correct mistyped commands, then remember them.
# false = disable (UNKNOWN messages just get a generic reply)
AI_COMMAND_LEARNING_ENABLED=true
# confidence >= HIGH -> act + learn automatically; [MIN, HIGH) -> ask the user to confirm first
AI_COMMAND_CONFIDENCE_HIGH=0.8
AI_COMMAND_CONFIDENCE_MIN=0.5

# ============================================================
# Dashboard / API auth
# ============================================================
# Bearer token protecting /api/records, /api/dashboard, /api/seed
DASHBOARD_API_KEY=your_secure_api_key_here

# Optional: read token for the LINE PDF-report link (/report.html + /api/reports/data).
# If unset, a stable hash of DASHBOARD_API_KEY is used so the raw key is never
# exposed in the link the bot sends. Set a custom value to rotate report access.
# REPORT_TOKEN=your_report_link_token

# ============================================================
# Shops (optional — defaults shown)
# ============================================================
DEFAULT_SHOP_ID=shop1
DEFAULT_SHOP_NAME=ก๋วยเตี๋ยวไทยครูตอมตลาดญี่ปุ่น
SHOP2_ID=shop2
SHOP2_NAME=ก๋วยเตี๋ยวไทยครูตอมสายหนองปิง

# ============================================================
# Application Configuration
# ============================================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================================
# Rate Limiting (optional)
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# Logging (optional)
# ============================================================
LOG_LEVEL=info
