# ============================================================
# LINE Bot Configuration
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# ============================================================
# Supabase Configuration (Database + Storage)
# ============================================================
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key (server-side only — bypasses RLS)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ============================================================
# Gemini AI Configuration (OCR + financial message parsing)
# ============================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
# 0 = auto from gemini-timing.ts (default 8250ms); override after npm run benchmark:natural-reply
GEMINI_NATURAL_REPLY_TIMEOUT_MS=0

# ============================================================
# Dashboard / API auth
# ============================================================
# Bearer token protecting /api/records, /api/dashboard, /api/seed
DASHBOARD_API_KEY=your_secure_api_key_here

# ============================================================
# Shops (optional — defaults shown)
# ============================================================
DEFAULT_SHOP_ID=shop1
DEFAULT_SHOP_NAME=ก๋วยเตี๋ยวไทยครูตอมตลาดญี่ปุ่น
SHOP2_ID=shop2
SHOP2_NAME=ก๋วยเตี๋ยวไทยครูตอมสายหนองปิง

# ============================================================
# Application Configuration
# ============================================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================================
# Rate Limiting (optional)
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# Logging (optional)
# ============================================================
LOG_LEVEL=info
